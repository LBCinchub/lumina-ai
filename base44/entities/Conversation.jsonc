{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        }
      }
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": []
}