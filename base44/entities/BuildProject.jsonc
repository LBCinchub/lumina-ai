{
  "name": "BuildProject",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Project name"
    },
    "html": {
      "type": "string",
      "description": "Latest generated HTML content"
    },
    "messages": {
      "type": "array",
      "description": "Chat history for this project",
      "items": {
        "type": "object"
      }
    },
    "last_built_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the project was last built"
    },
    "github_repo": {
      "type": "string",
      "description": "GitHub repo (owner/repo) for auto-sync"
    },
    "github_path": {
      "type": "string",
      "description": "File path in repo for auto-sync"
    },
    "github_auto_sync": {
      "type": "boolean",
      "default": false,
      "description": "Enable auto-sync to GitHub on save"
    }
  },
  "required": [
    "title"
  ],
  "rls": {
    "read": {
      "created_by": "{{user.email}}"
    },
    "write": {
      "created_by": "{{user.email}}"
    }
  }
}